# ============================================
# CrackD — Single Environment Configuration
# ============================================
# This file lives at the REPO ROOT (crackd/.env)
# NOT inside frontend/
#
# next.config.mjs loads it via dotenv from ../
# On Render: set these as Environment Variables
# ============================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_CRACKD_API_URL=https://crackd-dev.onrender.com/api
